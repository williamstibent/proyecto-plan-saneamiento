# Copia este archivo a .env y ajusta los valores.
# NUNCA subas .env al repositorio.

# Base de datos local (usada con docker-compose)
DATABASE_URL=jdbc:postgresql://localhost:5432/sanitia_dev
DATABASE_USERNAME=sanitia
DATABASE_PASSWORD=sanitia_pass

# AWS (en dev local puedes dejar vacíos si no usas S3/SQS)
AWS_REGION=us-east-1
S3_EVIDENCE_BUCKET=sanitia-evidence-dev

# Cognito (en dev local se deja vacío — la seguridad está abierta)
COGNITO_ISSUER_URI=

# Perfil activo
SPRING_PROFILES_ACTIVE=dev
