# Copia este archivo a .env.local (Vite lo carga automáticamente).
# Las variables deben empezar con VITE_ para ser expuestas al cliente.

# URL del backend (en dev Vite ya hace proxy, solo necesario para producción)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Cognito (se configura en Sprint 1)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
